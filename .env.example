# Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/contractor_ai
REDIS_URL=redis://localhost:6379

# Microsoft OAuth (Azure AD)
MSAL_CLIENT_ID=
MSAL_CLIENT_SECRET=
MSAL_TENANT_ID=

# OneDrive
ONEDRIVE_API_ENDPOINT=https://graph.microsoft.com/v1.0
ONEDRIVE_TENANT_ID=

# AI / Chat/RAG System
ANTHROPIC_API_KEY=   # For Claude (Query parsing + Response generation)
OPENAI_API_KEY=      # For embeddings
PINECONE_API_KEY=    # Vector database
PINECONE_INDEX=projectdashboard
VECTOR_STORE_PROVIDER=pinecone

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Environment
NODE_ENV=development
PORT=3000
