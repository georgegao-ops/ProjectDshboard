{
  "name": "@contractor/backend",
  "version": "0.0.1",
  "description": "ContractorAI Backend API (Node.js + Express)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "drizzle-kit push:pg --config ./drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "test": "vitest run --config ./vitest.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@contractor/shared": "workspace:*",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.0",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.20.0",
    "supertest": "^7.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
